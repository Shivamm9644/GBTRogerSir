# Fastlane Environment Variables Example
# Copy this to .env and fill in your details

# Android
# The path to your google_play_key.json (relative to fastlane folder)
SUPPLY_JSON_KEY=google_play_key.json

# iOS (App Store Connect API Key - Recommended)
# Get these from https://appstoreconnect.apple.com/access/api
# SPACESHIP_CONNECT_API_KEY_ID=YOUR_KEY_ID
# SPACESHIP_CONNECT_API_ISSUER_ID=YOUR_ISSUER_ID
# SPACESHIP_CONNECT_API_KEY_CONTENT="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Legacy iOS (Apple ID - Requires 2FA session)
# FASTLANE_USER=serialcoder90@gmail.com
# FASTLANE_PASSWORD=YOUR_APP_SPECIFIC_PASSWORD
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=YOUR_APP_SPECIFIC_PASSWORD

# Default App Identifier (Can be overridden by DB)
# FASTLANE_APP_IDENTIFIER=Inurum.Technology.EldTruckTrace
